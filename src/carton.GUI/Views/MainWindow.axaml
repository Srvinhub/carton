<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:carton.ViewModels"
        xmlns:views="using:carton.Views.Pages"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:carton.GUI.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
        x:Class="carton.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/carton_icon.png"
        Title="{DynamicResource App.Name}"
        Width="920" Height="640"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur">

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,8">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="{DynamicResource App.Name}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <Ellipse Width="10" Height="10"
                   Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusConverter}}"
                   VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ConnectionStatus}"
                     FontSize="12"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <TextBlock Grid.Column="1"
                   Text="{Binding CurrentPage.Title}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="Medium"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button Content="{DynamicResource MainWindow.Button.Start}" Command="{Binding ToggleConnectionCommand}"
                  Classes="accent"
                  IsVisible="{Binding ShowStartButton}"/>
          <Button Content="{DynamicResource MainWindow.Button.Stop}" Command="{Binding ToggleConnectionCommand}"
                  IsVisible="{Binding ShowStopButton}"/>
        </StackPanel>
      </Grid>
    </Border>

    <SplitView Grid.Row="1"
               IsPaneOpen="{Binding IsPaneOpen}"
               DisplayMode="Inline"
               OpenPaneLength="200"
               CompactPaneLength="50">
      <SplitView.Pane>
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
          <ListBox ItemsSource="{Binding NavigationPages}"
                   SelectedItem="{Binding SelectedPage}"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="models:NavigationPage">
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="12,8">
                  <PathIcon Width="20" Height="20"
                            Data="{Binding Converter={StaticResource NavigationIconConverter}}"/>
                  <TextBlock Text="{Binding Converter={StaticResource NavigationTitleConverter}}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </SplitView.Pane>

      <Grid>
        <views:DashboardView DataContext="{Binding DashboardViewModel}"
                             IsVisible="{Binding #MainWindowRoot.DataContext.IsDashboardPage}"/>
        <views:GroupsView DataContext="{Binding ActiveGroupsViewModel}"
                          IsVisible="{Binding #MainWindowRoot.DataContext.IsGroupsPage}"/>
        <ContentControl Content="{Binding ActiveTransientPage}"
                        IsVisible="{Binding #MainWindowRoot.DataContext.IsTransientPage}"/>
      </Grid>
    </SplitView>

    <OverlayLayer Grid.Row="0" Grid.RowSpan="2">
      <Panel IsVisible="{Binding ShowKernelDialog}">
        <Border Background="#80000000"/>
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                CornerRadius="8"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="400">
          <StackPanel Spacing="16">
            <TextBlock Text="{DynamicResource MainWindow.KernelDialog.Title}" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">
              <Run Text="{DynamicResource MainWindow.KernelDialog.DescriptionLine1}"/>
              <LineBreak/>
              <Run Text="{DynamicResource MainWindow.KernelDialog.LatestVersionPrefix}"/>
              <Run Text="{Binding LatestVersion}" FontWeight="Medium"/>
            </TextBlock>
            
            <ProgressBar IsIndeterminate="False"
                         Value="{Binding DownloadProgress}"
                         Maximum="100"
                         IsVisible="{Binding IsDownloadingKernel}"
                         Height="4"/>
            
            <TextBlock Text="{Binding DownloadStatus}"
                       IsVisible="{Binding IsDownloadingKernel}"
                       FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Content="{DynamicResource MainWindow.KernelDialog.Button.Download}" 
                      Command="{Binding DownloadKernelCommand}"
                      Classes="accent"
                      IsEnabled="{Binding !IsDownloadingKernel}"/>
              <Button Content="{DynamicResource MainWindow.KernelDialog.Button.Later}" 
                      Command="{Binding CloseKernelDialogCommand}"
                      IsEnabled="{Binding !IsDownloadingKernel}"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Panel>
    </OverlayLayer>
  </Grid>

</Window>

