<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:carton.ViewModels"
        xmlns:views="using:carton.Views.Pages"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:carton.GUI.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
        x:Class="carton.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="vm:MainViewModel"
        Title="{DynamicResource App.Name}"
        Width="900" Height="640"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="None">

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,8">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="{DynamicResource App.Name}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <Ellipse Width="10" Height="10"
                   Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusConverter}}"
                   VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ConnectionStatus}"
                     FontSize="12"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <TextBlock Grid.Column="1"
                   Text="{Binding CurrentPage.Title}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="Medium"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button Content="{DynamicResource MainWindow.Button.Start}" Command="{Binding ToggleConnectionCommand}"
                  Classes="accent"
                  IsVisible="{Binding ShowStartButton}"/>
          <Button Content="{DynamicResource MainWindow.Button.Stop}" Command="{Binding ToggleConnectionCommand}"
                  IsVisible="{Binding ShowStopButton}"/>
        </StackPanel>
      </Grid>
    </Border>

    <SplitView Grid.Row="1"
               IsPaneOpen="{Binding IsPaneOpen}"
               DisplayMode="Inline"
               OpenPaneLength="200"
               CompactPaneLength="200">
      <SplitView.Pane>
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0"
                        Margin="0,28,0,24"
                        HorizontalAlignment="Center"
                        Spacing="12">
              <Image Width="52"
                     Height="52"
                     Source="/Assets/carton_icon.png"/>
              <TextBlock Text="{DynamicResource App.Name}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1"
                  Margin="6,4,0,12"
                  ColumnDefinitions="8,*">
              <Canvas Grid.Column="0"
                      Width="8"
                      IsHitTestVisible="False">
                <Border Width="3"
                        Height="18"
                        Background="{DynamicResource SystemAccentColor}"
                        CornerRadius="2"
                        HorizontalAlignment="Left"
                        Margin="{Binding NavigationIndicatorOffset, Converter={StaticResource NavigationIndicatorMarginConverter}}">
                  <Border.Transitions>
                    <Transitions>
                      <ThicknessTransition Property="Margin" Duration="0:0:0.18"/>
                    </Transitions>
                  </Border.Transitions>
                </Border>
              </Canvas>

              <ListBox Grid.Column="1"
                       Classes="navPane"
                       ItemsSource="{Binding NavigationPages}"
                       SelectedItem="{Binding SelectedPage}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:NavigationPage">
                    <Grid ColumnDefinitions="20,*"
                          ColumnSpacing="12"
                          VerticalAlignment="Center">
                      <PathIcon Grid.Column="0"
                                Width="18"
                                Height="18"
                                Data="{Binding Converter={StaticResource NavigationIconConverter}}"
                                Foreground="{Binding $parent[ListBoxItem].Foreground}"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Converter={StaticResource NavigationTitleConverter}}"
                                 VerticalAlignment="Center"
                                 Foreground="{Binding $parent[ListBoxItem].Foreground}"/>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Grid>
        </Border>
      </SplitView.Pane>

      <Grid>
        <views:DashboardView DataContext="{Binding DashboardViewModel}"
                             IsVisible="{Binding #MainWindowRoot.DataContext.IsDashboardPage}"/>
        <views:GroupsView DataContext="{Binding ActiveGroupsViewModel}"
                          IsVisible="{Binding #MainWindowRoot.DataContext.IsGroupsPage}"/>
        <ContentControl Content="{Binding ActiveTransientPage}"
                        IsVisible="{Binding #MainWindowRoot.DataContext.IsTransientPage}"/>
      </Grid>
    </SplitView>

    <ContentControl Grid.Row="0"
                    Grid.RowSpan="2"
                    Content="{Binding KernelDialogHost}">
      <ContentControl.ContentTemplate>
        <DataTemplate DataType="vm:MainViewModel">
          <Grid Background="#80000000">
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="400"
                    MaxWidth="560">
              <StackPanel Spacing="16">
                  <TextBlock Text="{DynamicResource MainWindow.KernelDialog.Title}" FontSize="18" FontWeight="SemiBold"/>
                  <TextBlock TextWrapping="Wrap">
                    <Run Text="{DynamicResource MainWindow.KernelDialog.DescriptionLine1}"/>
                    <LineBreak/>
                    <Run Text="{DynamicResource MainWindow.KernelDialog.LatestVersionPrefix}"/>
                    <Run Text="{Binding LatestVersion}" FontWeight="Medium"/>
                  </TextBlock>

                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource Settings.Kernel.Mirror}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding KernelDownloadMirrors}"
                              SelectedItem="{Binding SelectedKernelDownloadMirror}"
                              MinWidth="150"
                              IsEnabled="{Binding !IsDownloadingKernel}"/>
                  </Grid>

                  <ProgressBar IsIndeterminate="False"
                               Value="{Binding DownloadProgress}"
                               Maximum="100"
                               IsVisible="{Binding IsDownloadingKernel}"
                               Height="4"/>

                  <TextBlock Text="{Binding DownloadStatus}"
                             TextWrapping="Wrap"
                             FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="{Binding KernelPrimaryActionText}"
                            Command="{Binding DownloadKernelCommand}"
                            Classes="accent"
                            IsEnabled="{Binding !IsDownloadingKernel}"/>
                    <Button Content="{DynamicResource MainWindow.KernelDialog.Button.Later}"
                            Command="{Binding CloseKernelDialogCommand}"
                            IsEnabled="{Binding !IsDownloadingKernel}"/>
                  </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </DataTemplate>
      </ContentControl.ContentTemplate>
    </ContentControl>
  </Grid>

</Window>
