<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:carton.ViewModels"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="carton.Views.Pages.ProfilesView"
             x:DataType="vm:ProfilesViewModel">
	<UserControl.Styles>
		<Style Selector="ListBoxItem">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>
		</Style>
		<Style Selector="ListBoxItem:pointerover">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
		</Style>
		<Style Selector="ListBoxItem:selected">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
		</Style>
		<Style Selector="Button.profile-row">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="8,8,0,8"/>
		</Style>
		<Style Selector="Button.profile-row:pointerover">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
		</Style>
 		<Style Selector="Button.profile-row:pressed">
 			<Setter Property="Background" Value="Transparent"/>
 			<Setter Property="BorderBrush" Value="Transparent"/>
 		</Style>
		<Style Selector="Button.iconButton">
			<Setter Property="Width" Value="30"/>
			<Setter Property="Height" Value="30"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="CornerRadius" Value="15"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
		</Style>
		<Style Selector="Button.iconButton:pointerover">
			<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
		</Style>
		<Style Selector="Button.iconButton:pressed">
			<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
		</Style>
 	</UserControl.Styles>

	<Grid RowDefinitions="Auto,Auto,*">
		<Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="10">
			<Grid ColumnDefinitions="Auto,*">
				<Button Grid.Column="0"
						Classes="iconButton"
						Command="{Binding CancelCreateCommand}"
						IsVisible="{Binding IsProfileFormMode}"
						Margin="0,0,10,0"
						ToolTip.Tip="{DynamicResource Profiles.Button.Back}">
					<PathIcon Width="14"
							  Height="14"
							  Data="M14.71 6.71L13.29 5.29L6.59 12L13.29 18.71L14.71 17.29L9.41 12L14.71 6.71Z"/>
				</Button>
				<TextBlock Grid.Column="1"
						   Text="{DynamicResource Profiles.Header.Title}"
						   FontSize="24"
						   FontWeight="SemiBold"
						   VerticalAlignment="Center"/>
			</Grid>
		</Border>

		<Border Grid.Row="1"
				IsVisible="{Binding ImportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
				Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
				BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
				BorderThickness="0,0,0,1"
				Padding="10,6">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<ProgressBar IsIndeterminate="True" IsVisible="{Binding IsImporting}" Width="80" Height="4"/>
				<TextBlock Text="{Binding ImportStatus}" VerticalAlignment="Center"/>
			</StackPanel>
		</Border>

		<Grid Grid.Row="2">
			<ScrollViewer IsVisible="{Binding !IsProfileFormMode}"
						  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
				<Border Margin="20"
						BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
						BorderThickness="1"
						CornerRadius="8"
						Padding="12">
					<StackPanel Spacing="0">
						<Grid ColumnDefinitions="*,Auto">
							<Button Grid.Column="1"
									Classes="iconButton"
									Command="{Binding ShowCreateProfileDialogCommand}"
									ToolTip.Tip="{DynamicResource Profiles.Button.NewProfile}">
								<PathIcon Width="14"
										  Height="14"
										  Data="M19 11H13V5H11V11H5V13H11V19H13V13H19V11Z"/>
							</Button>
						</Grid>
						<Separator Margin="0,8"/>

						<ItemsControl ItemsSource="{Binding Profiles}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
											BorderThickness="0,0,0,1"
											Padding="6,12">
										<Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
											<Button Grid.Column="0"
													Classes="profile-row"
													Background="Transparent"
													BorderBrush="Transparent"
													BorderThickness="0"
													HorizontalAlignment="Stretch"
													HorizontalContentAlignment="Left"
													Command="{Binding $parent[ItemsControl].((vm:ProfilesViewModel)DataContext).EditProfileCommand}"
													CommandParameter="{Binding}">
												<StackPanel Spacing="4">
													<TextBlock Text="{Binding DisplayName}"
															   FontSize="18"
															   FontWeight="SemiBold"/>
													<TextBlock FontSize="13"
															   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
														<Run Text="{DynamicResource Profiles.List.LastUpdatedLabel}"/>
														<Run Text="{Binding LastUpdated}"/>
													</TextBlock>
												</StackPanel>
											</Button>

											<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
												<Button Classes="iconButton"
														Command="{Binding $parent[ItemsControl].((vm:ProfilesViewModel)DataContext).UpdateProfileCommand}"
														CommandParameter="{Binding}"
														IsVisible="{Binding IsRemoteType}"
														ToolTip.Tip="{DynamicResource Profiles.Button.Update}">
													<PathIcon Width="14"
															  Height="14"
															  Data="M12 5 V1 L7 6 L12 11 V7 C15.3 7 18 9.7 18 13 C18 16.3 15.3 19 12 19 C8.7 19 6 16.3 6 13 H4 C4 17.4 7.6 21 12 21 C16.4 21 20 17.4 20 13 C20 8.6 16.4 5 12 5 Z"/>
												</Button>
												<Button Classes="iconButton"
														Command="{Binding $parent[ItemsControl].((vm:ProfilesViewModel)DataContext).DeleteProfileCommand}"
														CommandParameter="{Binding}"
														ToolTip.Tip="{DynamicResource Profiles.Button.Delete}">
													<PathIcon Width="14"
															  Height="14"
															  Data="M9 3V4H4V6H5V19A2 2 0 0 0 7 21H17A2 2 0 0 0 19 19V6H20V4H15V3H9M7 6H17V19H7V6M9 8V17H11V8H9M13 8V17H15V8H13Z"/>
												</Button>
											</StackPanel>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</Border>
			</ScrollViewer>

			<ScrollViewer IsVisible="{Binding IsProfileFormMode}"
						  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
				<StackPanel Margin="20" Spacing="16" MaxWidth="500">
					<TextBlock Text="{Binding ProfileFormTitle}" FontSize="18" FontWeight="SemiBold"/>

					<StackPanel Spacing="12">
						<Grid ColumnDefinitions="100,*" ColumnSpacing="12">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.NameLabel}" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Text="{Binding NewProfileName}"
									 Watermark="{DynamicResource Profiles.Form.NameWatermark}"/>
						</Grid>

						<Grid ColumnDefinitions="100,*" ColumnSpacing="12">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.TypeLabel}" VerticalAlignment="Center"/>
							<ComboBox Grid.Column="1"
									  ItemsSource="{Binding ProfileTypes}"
									  SelectedIndex="{Binding NewProfileType}"
									  IsEnabled="{Binding IsTypeEditable}"
									  HorizontalAlignment="Stretch"/>
						</Grid>

						<Grid ColumnDefinitions="100,*" ColumnSpacing="12"
							  IsVisible="{Binding ShowLocalFileModeSelector}">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.FileLabel}" VerticalAlignment="Center"/>
							<ComboBox Grid.Column="1"
									  ItemsSource="{Binding LocalModes}"
									  SelectedIndex="{Binding NewLocalMode}"
									  IsEnabled="{Binding IsLocalModeEditable}"
									  HorizontalAlignment="Stretch"/>
						</Grid>

						<Grid ColumnDefinitions="100,*,Auto" ColumnSpacing="12"
							  IsVisible="{Binding ShowLocalImportFilePicker}">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.FileLabel}" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1"
									 Text="{Binding NewLocalFilePath}"
									 IsReadOnly="True"
									 Watermark="{DynamicResource Profiles.Form.FileWatermark}"/>
							<Button Grid.Column="2"
									Content="{DynamicResource Profiles.Form.BrowseButton}"
									Command="{Binding BrowseLocalFileCommand}"
									IsEnabled="{Binding IsLocalModeEditable}"/>
						</Grid>

						<Grid ColumnDefinitions="100,*" ColumnSpacing="12"
							  IsVisible="{Binding IsRemoteProfile}">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.UrlLabel}" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1"
									 Text="{Binding NewProfileUrl}"
									 Watermark="{DynamicResource Profiles.Form.UrlWatermark}"/>
						</Grid>

						<Grid ColumnDefinitions="100,*,Auto" ColumnSpacing="12"
							  IsVisible="{Binding IsRemoteProfile}">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.AutoUpdateLabel}" VerticalAlignment="Center"/>
							<ToggleSwitch Grid.Column="2"
										  Classes="OnlySwitch"
										  IsChecked="{Binding NewAutoUpdate}"/>
						</Grid>

						<Grid ColumnDefinitions="100,*" ColumnSpacing="12"
							  IsVisible="{Binding IsRemoteProfile}">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.IntervalLabel}" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1"
									 Text="{Binding NewUpdateIntervalMinutes}"
									 Watermark="{DynamicResource Profiles.Form.IntervalWatermark}"/>
						</Grid>

						<Grid ColumnDefinitions="100,*" ColumnSpacing="12"
							  IsVisible="{Binding IsRemoteEditStatusVisible}">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.LastUpdatedLabel}" VerticalAlignment="Center"/>
							<TextBlock Grid.Column="1" Text="{Binding EditLastUpdated}"
									   VerticalAlignment="Center"
									   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
						</Grid>

						<Grid ColumnDefinitions="100,*" ColumnSpacing="12"
							  IsVisible="{Binding ShowContentAction}">
							<TextBlock Grid.Column="0" Text="{DynamicResource Profiles.Form.ActionLabel}" VerticalAlignment="Center"/>
							<Button Grid.Column="1"
									Content="{Binding ContentActionText}"
									Command="{Binding ToggleContentEditorCommand}"
									HorizontalAlignment="Left"/>
						</Grid>

						<TextBlock Text="{DynamicResource Profiles.Form.ContentLabel}"
								   IsVisible="{Binding ShowConfigEditor}"/>
						<TextBox Text="{Binding ConfigContent}"
								 Watermark="{DynamicResource Profiles.Form.ContentWatermark}"
								 AcceptsReturn="True"
								 TextWrapping="NoWrap"
								 Height="260"
								 FontFamily="monospace"
								 FontSize="11"
								 IsReadOnly="{Binding IsConfigReadOnly}"
								 IsVisible="{Binding ShowConfigEditor}"/>
					</StackPanel>

					<TextBlock Text="{Binding NewProfileStatus}"
							   IsVisible="{Binding NewProfileStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
							   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

					<ProgressBar IsIndeterminate="True"
								 IsVisible="{Binding IsCreating}"
								 Height="4"/>

					<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
						<Button Content="{DynamicResource Profiles.Form.CreateButton}" Command="{Binding CreateProfileCommand}"
								Classes="accent" IsEnabled="{Binding !IsCreating}"
								IsVisible="{Binding IsCreatingMode}"/>
						<Button Content="{DynamicResource Profiles.Form.SaveButton}" Command="{Binding SaveProfileCommand}"
								Classes="accent" IsEnabled="{Binding CanSaveProfile}"
								IsVisible="{Binding IsEditingMode}"/>
						<Button Content="{DynamicResource Profiles.Form.CancelButton}" Command="{Binding CancelCreateCommand}"
								IsEnabled="{Binding !IsCreating}"/>
					</StackPanel>
				</StackPanel>
			</ScrollViewer>
		</Grid>
	</Grid>

</UserControl>
