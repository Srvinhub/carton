<UserControl x:Name="GroupsViewRoot"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:carton.ViewModels"
             xmlns:helpers="using:carton.GUI.Helpers"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="600"
             x:Class="carton.Views.Pages.GroupsView"
             x:DataType="vm:GroupsViewModel">

  <Grid RowDefinitions="Auto,Auto,*">
    <Border Grid.Row="0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            Padding="16">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="代理组"
                   FontSize="24"
                   FontWeight="SemiBold"/>
        <ProgressBar Width="80"
                     Height="4"
                     IsVisible="{Binding IsLoading}"
                     IsIndeterminate="True"
                     Margin="12,0,0,0"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="10,6">
      <TextBlock Text="{Binding StatusMessage}"
                 VerticalAlignment="Center"/>
    </Border>

    <Grid Grid.Row="2"
          Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
          RowDefinitions="Auto,*"
          RowSpacing="12">
      <ListBox x:Name="GroupTabsListBox"
               Grid.Row="0"
                Margin="16,8,16,0"
                ItemsSource="{Binding Groups}"
                SelectedItem="{Binding SelectedGroup}"
                BorderThickness="0"
                Background="Transparent"
                Padding="0,0,0,12"
                IsVisible="{Binding ShowGroupTabs}"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollBarVisibility="Disabled">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="8"/>
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:GroupItemViewModel">
            <Border Padding="12,8"
                    CornerRadius="6"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1">
              <StackPanel>
                <TextBlock helpers:EmojiTextHelper.Text="{Binding Name}"
                           FontWeight="SemiBold"/>
                <TextBlock helpers:EmojiTextHelper.Prefix="{DynamicResource Groups.Label.Current}"
                           helpers:EmojiTextHelper.Text="{Binding SelectedOutbound}"
                           FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
          </Style>
          <Style Selector="ListBoxItem:selected Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
          </Style>
        </ListBox.Styles>
      </ListBox>

      <Border Grid.Row="1"
              Margin="16"
              Padding="16"
              CornerRadius="12"
              Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1">
        <ContentControl Content="{Binding SelectedGroup}">
          <ContentControl.ContentTemplate>
            <DataTemplate DataType="vm:GroupItemViewModel">
              <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Orientation="Horizontal"
                              Spacing="8">
                    <TextBlock helpers:EmojiTextHelper.Text="{Binding Name}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Type}"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock helpers:EmojiTextHelper.Prefix="{DynamicResource Groups.Label.Current}"
                               helpers:EmojiTextHelper.Text="{Binding SelectedOutbound}"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                  </StackPanel>

                  <Button Grid.Column="1"
                          Content="⚡"
                          Command="{Binding DataContext.TestCurrentGroupCommand, ElementName=GroupsViewRoot}"
                          Padding="8,4"
                          MinWidth="0"/>
                </Grid>

                <ScrollViewer x:Name="ProxiesScrollViewer"
                              Grid.Row="1"
                              Padding="0">
                  <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="vm:OutboundItemViewModel">
                        <Border Margin="4,0,4,8"
                                Padding="0"
                                CornerRadius="10"
                                BorderThickness="1"
                                HorizontalAlignment="Stretch"
                                Classes.selected="{Binding IsSelected}"
                                Classes.hovered="{Binding IsHovered}"
                                ToolTip.Tip="{Binding Tag}"
                                PointerEntered="OnProxyPointerEntered"
                                PointerExited="OnProxyPointerExited">
                          <Border.Styles>
                            <Style Selector="Border">
                              <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                              <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                            </Style>
                            <Style Selector="Border.hovered">
                              <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeHighBrush}"/>
                            </Style>
                            <Style Selector="Border.selected">
                              <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
                              <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
                            </Style>
                          </Border.Styles>

                          <Grid>
                            <Border Grid.RowSpan="2"
                                    Background="Transparent"
                                    CornerRadius="10"
                                    PointerPressed="OnProxySelectPressed"/>

                            <Grid Margin="12"
                                  RowDefinitions="Auto,Auto"
                                  RowSpacing="8"
                                  IsHitTestVisible="False">
                              <TextBlock helpers:EmojiTextHelper.Text="{Binding Tag}"
                                         FontSize="14"
                                         FontWeight="SemiBold"
                                         MaxLines="1"
                                         TextTrimming="CharacterEllipsis"/>

                              <TextBlock Grid.Row="1"
                                         Text="{Binding Type}"
                                         VerticalAlignment="Center"
                                         FontSize="12"
                                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="12,0,12,10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Panel.ZIndex="1">
                              <TextBlock Text="{Binding DelayDisplay}"
                                         VerticalAlignment="Center"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{Binding Delay, Converter={StaticResource LatencyForegroundConverter}}"
                                         IsHitTestVisible="False"/>
                              <Button Content="⚡"
                                      Command="{Binding TestDelayCommand}"
                                      Padding="8,2"
                                      MinWidth="0"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   ItemWidth="{Binding ElementName=ProxiesScrollViewer, Path=Bounds.Width, Converter={StaticResource ResponsiveItemWidthConverter}}"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </DataTemplate>
          </ContentControl.ContentTemplate>
        </ContentControl>
      </Border>
    </Grid>
  </Grid>

</UserControl>
