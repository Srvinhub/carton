<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:carton.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="carton.Views.Pages.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <ScrollViewer>
    <StackPanel Margin="20" Spacing="16">
      <Border Classes="card" Padding="20" IsEnabled="{Binding ShowStartupSelector}">
        <StackPanel Spacing="14">
          <TextBlock Text="{DynamicResource Dashboard.Section.Configuration}" FontSize="22" FontWeight="SemiBold"/>

          <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="Auto,120,Auto,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource Dashboard.Field.Port}"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding InboundPortText}"
                         IsReadOnly="{Binding IsPortInputReadOnly}"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="{Binding PortEditButtonText}"
                        Command="{Binding TogglePortEditCommand}"/>
              </Grid>

              <StackPanel Orientation="Horizontal" Spacing="18">
                <CheckBox Content="{DynamicResource Dashboard.Option.AllowLan}"
                          IsChecked="{Binding AllowLanConnections}"/>
                <CheckBox Content="{DynamicResource Dashboard.Option.SystemProxy}"
                          IsChecked="{Binding EnableSystemProxy}"/>
                <CheckBox Content="{DynamicResource Dashboard.Option.Tun}"
                          IsChecked="{Binding EnableTunInbound}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <StackPanel Spacing="12" IsVisible="{Binding ShowStartupSelector}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Grid.Column="0"
                         Text="{DynamicResource Dashboard.StartupPrompt}"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
              <Button Grid.Column="1"
                      Content="{DynamicResource Dashboard.Button.Start}"
                      Command="{Binding StartWithSelectedProfileCommand}"
                      Classes="accent"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding AvailableProfiles}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:DashboardProfileItemViewModel">
                  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                          BorderThickness="0,0,0,1"
                          Padding="6,10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                      <RadioButton Grid.Column="0"
                                   GroupName="startup-profile"
                                   IsChecked="{Binding IsSelected}"
                                   Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).SelectStartupProfileCommand}"
                                   CommandParameter="{Binding}"
                                   VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Name}"
                                 FontSize="16"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding StartupStatus}"
                       IsVisible="{Binding StartupStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel IsVisible="{Binding ShowDashboardMetrics}" Spacing="12">
        <Border Classes="card" Padding="14,10">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{DynamicResource Dashboard.CurrentProfileLabel}"
                         FontSize="12"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding CurrentProfile}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <Ellipse Width="10"
                       Height="10"
                       VerticalAlignment="Center"
                       Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusConverter}}"/>
              <TextBlock Text="{Binding StatusText}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </Border>

        <Border Classes="card" Padding="14,10">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8">
              <Button Content="{DynamicResource Dashboard.Button.CopyCmdProxy}"
                      Command="{Binding CopyTerminalProxyCommand}"
                      CommandParameter="cmd"
                      Padding="12,4"
                      IsVisible="{Binding IsWindows}"/>
              <Button Content="{DynamicResource Dashboard.Button.CopyPsProxy}"
                      Command="{Binding CopyTerminalProxyCommand}"
                      CommandParameter="ps"
                      Padding="12,4"
                      IsVisible="{Binding IsWindows}"/>
              <Button Content="{DynamicResource Dashboard.Button.CopyLinuxProxy}"
                      Command="{Binding CopyTerminalProxyCommand}"
                      CommandParameter="linux"
                      Padding="12,4"
                      IsVisible="{Binding IsLinux}"/>
              <Button Content="{DynamicResource Dashboard.Button.OpenWebUi}"
                      Command="{Binding OpenWebUiCommand}"
                      Padding="12,4"/>
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="{Binding StartupStatus}"
                       IsVisible="{Binding StartupStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

            <TextBlock Grid.Column="2"
                       Text="{Binding SessionStartTimeText, StringFormat='启动时间 {0}'}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Right"/>

            <Button Grid.Column="3"
                    Content="{DynamicResource Dashboard.Button.Stop}"
                    Command="{Binding StopConnectionCommand}"
                    Padding="12,4"
                    Classes="danger"
                    HorizontalAlignment="Right"/>
          </Grid>
        </Border>

        <Grid ColumnDefinitions="1.15*,1.6*,1.15*" ColumnSpacing="16">
          <Border Classes="card" Padding="18">
            <StackPanel Spacing="10">
              <TextBlock Text="{DynamicResource Dashboard.ClashMode}"
                         FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
              <ItemsControl ItemsSource="{Binding ClashModeOptions}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="vm:DashboardClashModeOptionViewModel">
                    <RadioButton Content="{Binding DisplayName}"
                                 GroupName="clash-mode"
                                 IsChecked="{Binding IsSelected}"
                                 Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).ChangeClashModeCommand}"
                                 CommandParameter="{Binding}"
                                 Margin="0,0,0,6"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Classes="card" Padding="18">
            <StackPanel Spacing="12">
              <TextBlock Text="{DynamicResource Dashboard.TrafficStats}"
                         FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="{DynamicResource Dashboard.Label.UploadSpeed}"
                             FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                  <TextBlock Text="{Binding UploadSpeed}"
                             FontSize="18"
                             FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="{DynamicResource Dashboard.Label.DownloadSpeed}"
                             FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                  <TextBlock Text="{Binding DownloadSpeed}"
                             FontSize="18"
                             FontWeight="SemiBold"/>
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="{DynamicResource Dashboard.Label.TotalUpload}"
                             FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                  <TextBlock Text="{Binding TotalUpload}"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="{DynamicResource Dashboard.Label.TotalDownload}"
                             FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                  <TextBlock Text="{Binding TotalDownload}"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Grid.Column="2" Classes="card" Padding="18">
            <StackPanel Spacing="12">
              <TextBlock Text="{DynamicResource Dashboard.KernelMemory.Title}"
                         FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

              <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Dashboard.KernelMemory.KernelVersion}"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock Text="{Binding KernelVersion}"
                           FontSize="18"
                           FontWeight="SemiBold"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Dashboard.KernelMemory.MemoryUsage}"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBlock Text="{Binding MemoryUsage}"
                           FontSize="18"
                           FontWeight="SemiBold"/>
              </StackPanel>

            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>

</UserControl>
